{
    "sectors": {
        "distressed_corporate": {
            "id": "sec_distressed_001",
            "label": "Distressed Corporate / Special Situations",
            "standard_sources": [],
            "extraction_schema": [
                "company_name",
                "company_description",
                "ebitda",
                "ownership",
                "advisor",
                "process_status"
            ]
        },
        "real_estate": {
            "id": "sec_re_001",
            "label": "Real Estate (Josh)",
            "standard_sources": [
                {
                    "id": "src_re_001",
                    "name": "The Gazette (Property & Insolvency)",
                    "url": "https://www.thegazette.co.uk/insolvency/notice?categorycode=2450",
                    "type": "watch",
                    "frequency": "daily"
                },
                {
                    "id": "src_re_002",
                    "name": "Allsop Commercial Auctions",
                    "url": "https://www.allsop.co.uk/commercial-auctions",
                    "type": "snapshot",
                    "frequency": "weekly"
                }
            ],
            "extraction_schema": [
                "company_name",
                "property_address",
                "guide_price",
                "yield_percent",
                "tenure_type",
                "lease_expiry",
                "insolvency_practitioner",
                "occupancy_rate",
                "debt_to_yield",
                "lha_exposure"
            ]
        },
        "tech_ma": {
            "id": "sec_tech_001",
            "label": "Tech / M&A",
            "standard_sources": [
                {
                    "id": "src_tech_001",
                    "name": "TechCrunch (Deals)",
                    "url": "https://techcrunch.com/category/startups/",
                    "type": "watch",
                    "frequency": "hourly"
                },
                {
                    "id": "src_tech_002",
                    "name": "Sifted (European VC)",
                    "url": "https://sifted.eu/sector/fintech",
                    "type": "snapshot",
                    "frequency": "daily"
                }
            ],
            "extraction_schema": [
                "company_name",
                "funding_round",
                "valuation_post_money",
                "lead_investor",
                "burn_rate",
                "runway_months",
                "rd_to_revenue_ratio"
            ]
        },
        "marine_logistics": {
            "id": "sec_mar_001",
            "label": "Marine / Logistics",
            "standard_sources": [
                {
                    "id": "src_mar_001",
                    "name": "Lloyd's List (Vessels)",
                    "url": "https://lloydslist.maritimeintelligence.informa.com/",
                    "type": "watch",
                    "frequency": "daily"
                },
                {
                    "id": "src_mar_002",
                    "name": "Baltic Exchange (Indices)",
                    "url": "https://www.balticexchange.com/",
                    "type": "snapshot",
                    "frequency": "daily"
                }
            ],
            "extraction_schema": [
                "vessel_name",
                "imo_number",
                "vessel_age",
                "imo_compliance",
                "charter_yield",
                "charter_rate_daily",
                "route_origin",
                "cargo_type_teu"
            ]
        },
        "talent_intelligence": {
            "id": "sec_talent_001",
            "label": "Talent Intelligence / Human Capital Analytics",
            "standard_sources": [
                {
                    "id": "src_talent_001",
                    "name": "Reed.co.uk (UK Jobs RSS)",
                    "url": "https://www.reed.co.uk/jobs?keywords={company_name}&proximity=10",
                    "type": "watch",
                    "frequency": "daily"
                },
                {
                    "id": "src_talent_002",
                    "name": "Adzuna API (UK Jobs)",
                    "url": "https://api.adzuna.com/v1/api/jobs/gb/search/1?app_id={app_id}&app_key={app_key}&what={company_name}",
                    "type": "api",
                    "frequency": "daily"
                }
            ],
            "extraction_schema": [
                "role_title",
                "department",
                "seniority",
                "location",
                "company_name",
                "hiring_signal_type",
                "compensation_band",
                "posting_date"
            ]
